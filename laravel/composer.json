{
  "name": "beavertech/tracker-laravel",
  "description": "BeaverTech tracker SDK for Laravel — sends application errors and logs to a BeaverTech error monitoring server.",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "beavertech",
    "error",
    "monitoring",
    "sentry",
    "logging",
    "tracker",
    "laravel"
  ],
  "homepage": "https://github.com/hadagalberto/beavertech-tracker",
  "authors": [
    {
      "name": "BeaverTech",
      "homepage": "https://github.com/hadagalberto/beavertech-tracker"
    }
  ],
  "support": {
    "issues": "https://github.com/hadagalberto/beavertech-tracker/issues",
    "source": "https://github.com/hadagalberto/beavertech-tracker/tree/main/laravel"
  },
  "require": {
    "php": ">=8.1",
    "illuminate/support": "^9.0|^10.0|^11.0",
    "illuminate/http": "^9.0|^10.0|^11.0",
    "illuminate/log": "^9.0|^10.0|^11.0",
    "illuminate/contracts": "^9.0|^10.0|^11.0"
  },
  "autoload": {
    "psr-4": {
      "BeaverTech\\ErrorMonitoring\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "BeaverTech\\ErrorMonitoring\\ErrorMonitoringServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
